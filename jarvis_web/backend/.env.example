# Backend
APP_NAME=Jarvis Web API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Banco SQLite (arquivo relativo ao diretório backend/)
DATABASE_URL=sqlite:///./jarvis_web.db

# Seed opcional de dados iniciais na primeira execução
DATABASE_SEED_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenAI
DEFAULT_OPENAI_MODEL=gpt-4.1-mini
